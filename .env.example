KONG_PG_HOST=host.docker.internal
KONG_PG_USER=root
KONG_DATABASE=postgres
KONG_PG_PASSWORD=1234
KONG_PG_DATABASE=kong
KONG_DOCKER_TAG=kong:latest
KONG_USER=kong
KONG_PROXY_LISTEN=8000
KONG_ADMIN_LISTEN=8001
KONG_SSL_PROXY_LISTEN=8443
KONG_SSL_ADMIN_LISTEN=8444
KONG_PREFIX=/var/run/kong
# KONG_CERT_DIR=./certs
# CERT_FILE=./certs/cert.pem
# CERT_KEY_FILE=./certs/key.pem
KONGA_LISTEN=1337
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=1234
KC_DB_URL=keycloak-db
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_PORT=8080
KC_HOSTNAME=0.0.0.0
KC_PROVIDER_DIR=./keycloak-providers
KC_THEMES_DIR=./keycloak-themes/onekey-theme
KC_CERT_DIR=./certs
# Non-prod banner: realm[:LABEL[:NOTE]], comma-separated. Empty = off. See docs/keycloak-env-banner.md
KC_ENV_BANNER_REALMS=
# Fallbacks used when a realm entry omits that segment.
KC_ENV_BANNER_DEFAULT_LABEL=DEVELOPMENT
KC_ENV_BANNER_DEFAULT_NOTE=Hanya untuk pengembangan

# Corporate email theme assets (empty = text wordmark fallback)
KC_EMAIL_LOGO_URL=          # header: OneKey wordmark logo
KC_EMAIL_FOOTER_LOGO_URL=   # footer: Petrokimia Gresik emblem
KC_EMAIL_SUPPORT_URL=       # footer: helpdesk web link
WEBHOOK_URL=http://webhook.url/endpoints
